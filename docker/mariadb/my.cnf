# =================================================================
# MariaDB 11.7 Config — Ujian Terpadu
# Optimized for 4 core / 8GB RAM / 6000 concurrent users
# Container memory limit: 768M
# Memory budget: 256M buffer + 48M log + 32M tmp + ~150M overhead = ~486M
# =================================================================

[mysqld]
# --- Character set ---
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# --- InnoDB tuning (fit within 768M container) ---
innodb_buffer_pool_size = 256M
innodb_log_file_size = 48M
innodb_log_buffer_size = 16M
innodb_flush_log_at_trx_commit = 2
innodb_io_capacity = 800
innodb_io_capacity_max = 1600
innodb_read_io_threads = 8
innodb_write_io_threads = 8
innodb_use_native_aio = OFF

# --- Connection tuning ---
# 3 app replicas × 8 workers + 3 queue workers + admin = ~30 active connections
# Set 150 to handle burst with 6000 concurrent users
max_connections = 150
wait_timeout = 120
interactive_timeout = 120
connect_timeout = 10
thread_cache_size = 48
thread_pool_size = 4

# --- Table & temp tables ---
tmp_table_size = 32M
max_heap_table_size = 32M
table_open_cache = 2000
table_definition_cache = 1000

# --- Sort / join buffers (per-connection, keep small to avoid OOM) ---
sort_buffer_size = 512K
join_buffer_size = 512K
read_buffer_size = 256K
read_rnd_buffer_size = 512K

# --- Query execution ---
max_allowed_packet = 64M
group_concat_max_len = 1048576

# --- Slow query log ---
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow.log
long_query_time = 1

# --- Binary log (disabled for single-server) ---
skip-log-bin

# --- Performance Schema (disable to save memory) ---
performance_schema = OFF

[client]
default-character-set = utf8mb4
