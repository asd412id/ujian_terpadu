# =================================================================
# MySQL 8.0 Config — Ujian Terpadu
# Optimized for 4 core / 4GB RAM / 2000 concurrent users
# Container memory limit: 768M
# =================================================================

[mysqld]
# --- Character set ---
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# --- InnoDB tuning (fit within 768M container) ---
innodb_buffer_pool_size = 384M
innodb_buffer_pool_instances = 2
innodb_log_file_size = 64M
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT
innodb_io_capacity = 400
innodb_io_capacity_max = 800
innodb_read_io_threads = 4
innodb_write_io_threads = 4

# --- Connection tuning ---
# 50 php-fpm workers + 2 queue workers + admin = ~60 active connections
# Set 150 to handle spikes and connection pooling overhead
max_connections = 150
wait_timeout = 120
interactive_timeout = 120
connect_timeout = 10
thread_cache_size = 50

# --- Table & temp tables ---
tmp_table_size = 32M
max_heap_table_size = 32M
table_open_cache = 2000
table_definition_cache = 1000

# --- Sort / join buffers (per-connection, keep small) ---
sort_buffer_size = 2M
join_buffer_size = 2M
read_buffer_size = 1M
read_rnd_buffer_size = 1M

# --- Query execution ---
max_allowed_packet = 64M
group_concat_max_len = 1048576

# --- Slow query log ---
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow.log
long_query_time = 1

# --- Binary log (disabled for single-server, enable for replication) ---
skip-log-bin

# --- Performance Schema (disable to save memory) ---
performance_schema = OFF

[client]
default-character-set = utf8mb4
